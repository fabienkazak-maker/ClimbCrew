{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tmp/tools.tsbuildinfo",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "noUncheckedIndexedAccess": true
  },
  "include": ["tools"]
}
