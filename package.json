{
  "name": "climbcrew-linux-server",
  "private": true,
  "version": "3.0.0-linux",
  "scripts": {
    "prod:config": "docker compose --env-file .env.production -f docker-compose.prod.yml config",
    "prod:build": "docker compose --env-file .env.production -f docker-compose.prod.yml build",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "prod:setup-db": "bash deploy/scripts/setup-db.sh .env.production",
    "prod:health": "bash deploy/scripts/healthcheck.sh .env.production",
    "legacy:validate": "node tools/validate-import-data.mjs ./backend/import-data.json"
  }
}
