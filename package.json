{
  "name": "climbcrew-local-windows",
  "private": true,
  "version": "2.3.0-secure-https-local",
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down --remove-orphans",
    "legacy:import": "powershell -ExecutionPolicy Bypass -File ./import-legacy-data.ps1",
    "legacy:reset": "powershell -ExecutionPolicy Bypass -File ./reset-dev-with-legacy-data.ps1",
    "legacy:validate": "node tools/validate-import-data.mjs ./backend/import-data.json",
    "server:build": "powershell -ExecutionPolicy Bypass -File ./build-server-local.ps1",
    "server:up": "docker compose -f docker-compose.server.yml up --build -d",
    "server:down": "docker compose -f docker-compose.server.yml down --remove-orphans",
    "cert:create": "powershell -ExecutionPolicy Bypass -File ./create-local-certificate.ps1",
    "cert:trust": "powershell -ExecutionPolicy Bypass -File ./trust-local-certificate.ps1",
    "server:https": "powershell -ExecutionPolicy Bypass -File ./start-server-https.ps1"
  }
}
